# =====================================================================
# Nozomio Hackathon — .env.example
# =====================================================================
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# `.env` is gitignored — never commit real secrets.
# See SETUP_CHECKLIST.md for step-by-step instructions on getting each
# key, including which sponsor booth to ask if the dashboard path fails.
# =====================================================================

# ---------- LLMs ----------
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel AI Gateway (optional — one key for all providers)
# https://vercel.com/dashboard/ai
AI_GATEWAY_API_KEY=

# ---------- Nia (host sponsor) ----------
# Easiest: run `npx nia-wizard@latest`
# Or: https://app.trynia.ai → Settings → API Keys
NIA_API_KEY=nia_xxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Hyperspell (DEDICATED TRACK) ----------
# https://www.hyperspell.com → Settings → API Keys
# (or ask Conor/Manu at the booth)
HYPERSPELL_API_KEY=hsp_xxxxxxxxxxxxxxxxxxxxxxxx
HYPERSPELL_TOKEN=hsp_xxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Devin (Cognition) ----------
# https://devin.ai → Settings → API Keys (Pro plan or higher)
DEVIN_API_KEY=cog_xxxxxxxxxxxxxxxxxxxxxxxx
DEVIN_ORG_ID=org_xxxxxxxxxxxxxxxx

# ---------- InsForge ----------
# https://insforge.dev → New Project → copy URL + anon key
INSFORGE_BASE_URL=https://your-project.insforge.app
INSFORGE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR...
INSFORGE_SERVICE_ROLE_KEY=

# ---------- Tensorlake ----------
# https://www.tensorlake.ai → Settings → API Keys
TENSORLAKE_API_KEY=tl_xxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Convex (auto-provisioned) ----------
# Run `npx convex dev` — these get written automatically
CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOYMENT=dev:your-project-name

# ---------- Optional: cross-cutting infra ----------
# GitHub PAT (for Devin/Codex on private repos)
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs (voice projects)
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=

# Browserbase (browser automation; Aside fallback)
# https://www.browserbase.com → Settings → API Keys
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# =====================================================================
# Sponsors with NO public API key (do not add a fake var):
#   - Reacher  → SaaS dashboard, 10-day trial only
#   - Aside    → waitlist; talk to founders at the EF venue
#   - AI Nexus → event organizer, not a tool
#   - OpenAI Codex → reuses OPENAI_API_KEY above
# =====================================================================
