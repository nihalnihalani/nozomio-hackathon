# =====================================================================
# Triage — .env.example
# =====================================================================
# Copy to .env and fill in values:  cp .env.example .env
# .env is gitignored. See SETUP_CHECKLIST.md for how to get each key.
#
# DEFAULT MODE: live. Production should fail visibly when required
# integrations are not configured.
# Set DEMO_MODE=replay only for explicit local fixture playback.
# =====================================================================

# ---------- Runtime mode ----------
# live (default; real services)  |  replay (cached fixtures)  |  hybrid (live with replay fallback)
DEMO_MODE=live
# Optional override. If unset, the server/Convex generates a stable single-tenant
# org id from TRIAGE_ORG_SEED or deployment URLs.
TRIAGE_DEFAULT_ORG_ID=
TRIAGE_ORG_SEED=acme-prod

# Optional: only needed when the browser should query org-scoped recent runs.
NEXT_PUBLIC_TRIAGE_ORG_ID=

# ---------- LLM (one provider required for live mode) ----------
# https://console.anthropic.com  → API keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# https://platform.openai.com  → API keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx

# ---------- Hyperspell (Track 4 sponsor) ----------
# https://www.hyperspell.com  or  ask Conor/Manu at the booth
HYPERSPELL_API_KEY=hsp_xxxxxxxxxxxxxxxxxxxxxxxx
HYPERSPELL_TOKEN=hsp_xxxxxxxxxxxxxxxxxxxxxxxx
HYPERSPELL_CONNECT_USER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Nia (host sponsor) ----------
# Easiest:  npx nia-wizard@latest
# Or:  https://app.trynia.ai → Settings → API Keys
NIA_API_KEY=nia_xxxxxxxxxxxxxxxxxxxxxxxx
NIA_SOURCE_ROOT=seed/billing-service
STRICT_CITE_OR_DIE=1

# ---------- Convex (auto-provisioned) ----------
# Run `npx convex dev` — these are written automatically
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOYMENT=dev:your-project-name

# ---------- InsForge (cold path) ----------
# https://insforge.dev  → New Project → copy URL + anon key
INSFORGE_BASE_URL=https://your-project.insforge.app
INSFORGE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR...
INSFORGE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR...
INSFORGE_MIRROR_SECRET=change-me

# ---------- Optional: replay tuning ----------
HYBRID_LIVE_BUDGET_MS=8000

# ---------- Optional: PostHog LLM Analytics ----------
# Per-LLM-call cost / latency / model traces converted from AI SDK
# `gen_ai` OpenTelemetry spans into PostHog `$ai_generation` events.
# Wired in convex/observability.ts (side-effect import in convex/triageNode.ts).
# Leave both blank to disable — the OTel provider becomes a silent no-op
# and the application runs unchanged.
# https://posthog.com/docs/llm-analytics/installation/convex
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
