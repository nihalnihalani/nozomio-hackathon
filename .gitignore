# Secrets — never commit
.env
.env.local
.env.*.local
!.env.example

# Node
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Next.js
.next/
out/
build/
dist/
next-env.d.ts
tsconfig.tsbuildinfo

# Convex
# `npx convex dev` codegens this directory. We commit hand-written
# typed stubs (api.d.ts + api.js) as a fallback so a fresh clone with
# no Convex auth still typechecks and builds — `lib/hooks/useTriage.ts`
# imports from `@/convex/_generated/api`. We ignore the codegen outputs
# individually rather than the whole directory so the negations below
# can re-include the committed fallback stubs (gitignore can't re-include
# files inside an excluded directory).
convex/_generated/*
!convex/_generated/api.d.ts
!convex/_generated/api.js

# Vercel
.vercel/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Agent runtime state (machine-local, not for repo)
.claude/agent-memory/
.omc/

# Logs
*.log
logs/

# Testing
coverage/
.vitest-cache/

# Demo backup video (large; generated)
docs/demo-backup.mp4

# Replay-mode generated artifacts (logs / markers)
data/replay/hyperspell/_writes.log
data/replay/hyperspell/_ingest-log.json
data/replay/hyperspell/.ingest-complete
