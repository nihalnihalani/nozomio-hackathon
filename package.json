{
  "name": "triage",
  "version": "0.1.0",
  "private": true,
  "description": "Incident-triage AI agent — Hyperspell + Nia + Convex + InsForge",
  "scripts": {
    "dev": "next dev",
    "dev:convex": "convex dev",
    "dev:all": "concurrently -n next,convex -c blue,magenta \"next dev\" \"convex dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "ingest": "tsx scripts/ingest.ts",
    "prewarm": "tsx scripts/prewarm_demo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:invariants": "vitest run tests/invariants && tsx scripts/verify_invariants.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/react": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "ai": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.18.0",
    "lucide-react": "^0.473.0",
    "next": "15.1.6",
    "react": "^19.0.0",
    "react-diff-viewer-continued": "^4.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
